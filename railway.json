{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "providers": ["node"],
    "buildCommand": "npm install && npx prisma generate",
    "env": {
      "NODE_VERSION": "22"
    }
  },
  "deploy": {
    "startCommand": "npx prisma db push && node server.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
